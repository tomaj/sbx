  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "pnpx @biomejs/biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "**/*.{json,css}": [
      "pnpx @biomejs/biome format --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
