{
  "name": "sbx",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "keywords": [],
