{
  "name": "@sbx/db",
  "version": "0.0.1",
  "description": "Shared Drizzle ORM schema for SBX",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-zod": "^0.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": ">=8",
    "zod": "^4.0.0"
  }
}
