PORT=3002

# MinIO (S3-compatible object storage for original assets)
MINIO_ENDPOINT=http://localhost:9090
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=assets
MINIO_REGION=us-east-1

# Redis (cache for transformed images)
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (default: 1 year)
CACHE_TTL=31536000
