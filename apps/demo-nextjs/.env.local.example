# SBX CDN API base URL (without /v2/cdn/ — app adds that itself)
NEXT_PUBLIC_SBX_API_URL=http://localhost:3000

# SBX Visual Editor Bridge URL (served by apps/api)
NEXT_PUBLIC_SBX_BRIDGE_URL=http://localhost:3000/bridge/v2-latest.js

# CDN access token for the space (preview/private token from api_tokens table)
# Get it from SBX admin → Space Settings → API Tokens
NEXT_PUBLIC_SBX_ACCESS_TOKEN=your-preview-token-here

# Space ID
NEXT_PUBLIC_SBX_SPACE_ID=285923
